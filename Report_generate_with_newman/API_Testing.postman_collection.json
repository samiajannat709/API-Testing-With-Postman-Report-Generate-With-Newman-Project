    {
      "name": "GetBookingIds",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// for status\r",
              "pm.test(\"status code is 200 \",function(){\r",
              "    pm.expect(pm.response.code).to.eql(200);\r",
              "});\r",
              "\r",
              "// for time\r",
              "pm.test(\"verify that the response time is showing as expected or not\", function(){\r",
              "    pm.expect(pm.response.responseTime).to.below(10000);\r",
              "});\r",
              "\r",
              "// for size\r",
              "pm.test(\"verify the expected size\",function(){\r",
              "    pm.expect(pm.response.responseSize).to.below(100000);\r",
              "});\r",
              "\r",
              "// Assertion for data format\r",
              "pm.test(\"Verify the json data format as expected or not\",function(){\r",
              "    pm.response.to.have.jsonBody();\r",
              "});\r",
              "var responseBody=pm.response.json();\r",
              "// Assertion for checking booking id 70 is prresent or not\r",
              "pm.test(\"Verify the booking id 3 is present or not\",function(){\r",
              "    var exists=responseBody.some(item=>item.bookingid===3);\r",
              "    pm.expect(exists).to.be.true;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
