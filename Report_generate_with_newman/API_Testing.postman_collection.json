    {
      "name": "CreateBooking",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "//for fn\r",
              "var fn=pm.variables.replaceIn('{{$randomFirstName}}');\r",
              "pm.environment.set(\"fname\",fn);\r",
              "\r",
              "//for ln\r",
              "var ln=pm.variables.replaceIn(\"{{$randomLastName}}\");\r",
              "pm.environment.set(\"lname\",ln);\r",
              "\r",
              "//for tp\r",
              "var tp=pm.variables.replaceIn(\"{{$randomInt}}\");\r",
              "pm.environment.set(\"tp\",tp);\r",
              "\r",
              "//for dp\r",
              "var dp=pm.variables.replaceIn(\"{{$randomBoolean}}\");\r",
              "pm.environment.set(\"dp\",dp);\r",
              "\r",
              "//for ci\r",
              "var ci=require(\"moment\");\r",
              "var cid=ci().format(\"YYYY-MM-DD\");\r",
              "pm.environment.set(\"ci\",cid);\r",
              "\r",
              "//for co\r",
              "var co=require(\"moment\");\r",
              "var cod=co().add(4,'d').format(\"YYYY-MM-DD\");\r",
              "pm.environment.set(\"co\",cod);\r",
              "\r",
              "// for an\r",
              "var an=pm.variables.replaceIn(\"{{$randomBsNoun}}\");\r",
              "pm.environment.set(\"adneed\",an);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var responseBody = pm.response.json();\r",
              "pm.environment.set(\"id\",responseBody.bookingid);\r",
              "\r",
              "// for status\r",
              "pm.test(\"the status is 201?\",function(){\r",
              "    pm.expect(pm.response.code).to.eql(201);\r",
              "});\r",
              "\r",
              "// for time\r",
              "pm.test(\"verify the time is showing as ecpected or not\",function(){\r",
              "    pm.expect(pm.response.responseTime).to.below(1000);\r",
              "});\r",
              "\r",
              "// for size\r",
              "pm.test(\"verify the expected size\",function(){\r",
              "    pm.expect(pm.response.responseSize).to.below(100000);\r",
              "});\r",
              "\r",
              "var responseBody=pm.response.json();\r",
              "// Assertion for firstname\r",
              "pm.test(\"Verify the firstname is showing as expected or not\",function(){\r",
              "    pm.expect(pm.environment.get(\"fname\")).to.eql(responseBody.booking.firstname);\r",
              "});\r",
              "\r",
              "// for lastname\r",
              "pm.test(\"Verify the last name is expected or not\",function(){\r",
              "    pm.expect(pm.environment.get(\"lname\")).to.eql(responseBody.booking.lastname);\r",
              "});\r",
              "\r",
              "// for totalprice\r",
              "pm.test(\"Verify totalprice\",function(){\r",
              "    pm.expect(pm.environment.get(\"tp\")).to.eql(responseBody.booking.totalprice.toString());\r",
              "});\r",
              "\r",
              "// for depositpaid\r",
              "pm.test(\"Verify the depositpaid is expected or not\",function(){\r",
              "    pm.expect(pm.environment.get(\"dp\")).to.eql(responseBody.booking.depositpaid.toString());\r",
              "});\r",
              "\r",
              "// for ci\r",
              "pm.test(\"Verify checkin is expected or not\",function(){\r",
              "    pm.expect(pm.environment.get(\"ci\")).to.eql(responseBody.booking.bookingdates.checkin);\r",
              "});\r",
              "\r",
              "// for code\r",
              "pm.test(\"Verify the checkout is showing as expected or not\", function(){\r",
              "    pm.expect(pm.environment.get(\"co\")).to.eql(responseBody.booking.bookingdates.checkout);\r",
              "});\r",
              "\r",
              "// for additional needs\r",
              "pm.test(\"verify the additional needs is showing as expected or not\",function(){\r",
              "    pm.expect(pm.environment.get(\"adneed\")).to.eql(responseBody.booking.additionalneeds);\r",
              "});\r",
              "\r",
              "// Assertion for the data format\r",
              "pm.test(\"Verify the data format that it is json or not\",function(){\r",
              "    pm.response.to.have.jsonBody();\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
